{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "buildCommand": "cd frontend && npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "public": false,
  "functions": {
    "api/**/*.php": {
      "runtime": "php@8.4"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.php"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
