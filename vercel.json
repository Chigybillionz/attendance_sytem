{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "version": 2,
  "framework": "vite",
  "buildCommand": "npm ci && npm run build",
  "outputDirectory": "frontend/dist",
  "public": false,
  "env": ["VITE_API_URL"],
  "functions": {
    "api/**/*.php": {
      "runtime": "php@8.4"
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/backend/public/index.php"
    },
    {
      "source": "/(.*)",
      "destination": "/frontend/dist/index.html"
    }
  ]
}
